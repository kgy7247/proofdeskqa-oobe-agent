+function parseAuditTarget(rawUrl: string) {
+  const input = rawUrl.trim() || 'https://example.com/mcp';
+  const normalized = /^https?:\/\//i.test(input) ? input : `https://${input}`;
+
+  try {
+    const parsed = new URL(normalized);
+    return {
+      input,
+      url: parsed.toString(),
+      host: parsed.hostname,
+      path: parsed.pathname,
+      is_local: ['localhost', '127.0.0.1', '0.0.0.0'].includes(parsed.hostname),
+      uses_https: parsed.protocol === 'https:',
+    };
+  } catch {
+    return {
+      input,
+      url: 'https://example.com/mcp',
+      host: 'example.com',
+      path: '/mcp',
+      is_local: false,
+      uses_https: true,
+    };
+  }
+}
+
+function scoreAuditTarget(target: ReturnType<typeof parseAuditTarget>, toolCount: number) {
+  const score = 45
+    + (target.uses_https ? 15 : 0)
+    + (target.path.includes('mcp') ? 15 : 0)
+    + Math.min(toolCount, 4) * 5
+    - (target.is_local ? 20 : 0);
+
+  return Math.max(0, Math.min(100, score));
+}
+
+function splitTools(rawTools: string | undefined) {
+  return (rawTools || 'search,enrich,export,analyze')
+    .split(',')
+    .map((tool) => tool.trim())
+    .filter(Boolean)
+    .slice(0, 8);
+}
