    "bounty:oobe:demo": "node scripts/oobe-agent-demo.mjs",
    "bounty:oobe:ready": "node scripts/oobe-live-readiness.mjs",
    "bounty:oobe:report": "node scripts/oobe-submission-report.mjs"
  },
  "dependencies": {
    "@oobe-protocol-labs/synapse-client-sdk": "^2.0.6",
    "@oobe-protocol-labs/synapse-sap-sdk": "^0.13.0",
    "@virtuals-protocol/acp-node-v2": "^0.1.2",
    "phaser": "^3.90.0",
    "vite": "^6.0.7"
  },
  "devDependencies": {
    "typescript": "^5.7.3"
  }
}
